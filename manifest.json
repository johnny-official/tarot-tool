{
  "manifest_version": 3,
  "name": "Tarot QuickSale",
  "version": "3.0.0",
  "description": "Công cụ hỗ trợ nhân viên Sale Tarot chốt đơn nhanh - Cá, Dừa, Pờ Bơ",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "https://business.facebook.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://business.facebook.com/*"],
      "js": [
        "content/state.js",
        "content/constants.js",
        "content/detection.js",
        "content/storage.js",
        "content/readers.js",
        "content/orders.js",
        "content/ui.js",
        "content/main.js"
      ],
      "css": ["content.css"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_title": "Tarot QuickSale"
  },
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["price.json", "config.json"],
      "matches": ["https://business.facebook.com/*"]
    }
  ]
}
